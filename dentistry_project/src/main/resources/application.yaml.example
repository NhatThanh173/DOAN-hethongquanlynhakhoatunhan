server:
  servlet:
    context-path: /api

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/nha_khoa_db
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}

  jpa:
    hibernate:
      ddl-auto: validate
    open-in-view: false

  flyway:
    baseline-on-migrate: true

  data:
    redis:
      host: localhost
      port: 6379

  mail:
    host: smtp.gmail.com
    port: 587
    username: ${MAIL_USERNAME}
    password: ${MAIL_PASSWORD}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
    default-encoding: UTF-8

  thymeleaf:
    prefix: classpath:/templates/
    suffix: .html
    mode: HTML
    encoding: UTF-8
    cache: false

  ai:
    model:
      chat: google-genai
    google:
      genai:
        api-key: ${GEMINI_API_KEY}
        chat:
          options:
            model: gemini-2.0-flash

app:
  mail:
    from: "Nha Khoa Việt Smile <${MAIL_USERNAME}>"

jwt:
  access-token-expiration: 900
  refresh-token-expiration: 7d
  secret: ${JWT_SECRET}

springdoc:
  swagger-ui:
    path: /swagger

payment:
  vn-pay:
    vnpUrl: https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
    tmnCode: ${VNP_TMN_CODE}
    secretKey: ${VNP_SECRET_KEY}
    returnUrl: http://localhost:3000/payment/vnpay-return
    ipnUrl: http://localhost:8080/api/payments/vnpay/ipn
    version: 2.1.0
    command: pay
    orderType: other